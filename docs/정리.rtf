### 2.3 \uc0\u9314  \u50500 \u51060 \u46356 \u50612  \u49892 \u54788  \u48169 \u50504  (\u50557  900\u51088 )\
\
\uc0\u54645 \u49900  MVP \u53076 \u46300 \u45716  \u51060 \u48120  \u50756 \u49457 \u46096 \u49845 \u45768 \u45796 . React, TypeScript, Vite \u49828 \u53469 \u51004 \u47196  \u48512 \u45824 \'b7\u44592 \u49688 \'b7\u48372 \u51649 \'b7\u48373 \u47924  \u49884 \u44592  4\u52264 \u50896  \u47588 \u52845 , \u44400 \u48264 , \u51204 \u50669 \u51613  \u51064 \u51613 , \u51060 \u51473  \u50741 \u53944 \u51064  \u50672 \u44208 , \u51064 \u51613 \'b7DB\'b7\u49892 \u49884 \u44036  \u49828 \u53412 \u47560 \u47484  \u45800 \u51068  \u53076 \u46300 \u48288 \u51060 \u49828 \u50640  \u53685 \u54633  \u50756 \u47308 . \u48512 \u44032  \u47784 \u46280 (D-Day\'b7\u52404 \u53356 \u47532 \u49828 \u53944 \'b7\u51204 \u47928 \u44032  \u50504 \u45236 )\u46020  \u46041 \u51068  \u53076 \u46300 \u48288 \u51060 \u49828 \u50640  \u44396 \u54788  \u53076 \u46300 \u45716  \u45149 \u45228 \u44256  \u52636 \u49884 , \u44160 \u51613 , \u49828 \u52992 \u51068 \u50629  \u45800 \u44228 \u51077 \u45768 \u45796 .\
\
\uc0\u51204 \u52404 \u51201 \u51064  \u47196 \u46300 \u47605 \
- \uc0\u52636 \u49884 \u50752  \u51064 \u51613  \u49884 \u49828 \u53596  \u48372 \u44053 : \u46020 \u47700 \u51064  \u50672 \u44208  \u48143  \u44277 \u44060  \u48176 \u54252 , \u44400 \u48264 , \u51204 \u50669 \u51613  OCR \u51064 \u51613  \u49884 \u49828 \u53596  1\u52264  \u44032 \u46041 , \u44060 \u51064 \u51221 \u48372 \u48372 \u54840 \u48277  \u51456 \u49688  \u49444 \u44228  \u44160 \u51613 . \u49324 \u51204  \u44032 \u51077  \u44305 \u44256  \u49884 \u51089  (\u54168 \u51060 \u49828 \u48513  \u48512 \u45824  \u44536 \u47353 , \u45348 \u51060 \u48260  \u44400  \u52852 \u54168 , \u46356 \u49884  \u44400  \u44068 \u47084 \u47532  \u53440 \u44191 ).\
- \uc0\u49324 \u50857 \u51088  \u54869 \u48372  \u48143  \u54645 \u49900  \u48512 \u45824  \u45936 \u51060 \u53552  \u44396 \u52629 : \u49324 \u50857 \u51088  5,000\u47749  \u47785 \u54364 . \u54645 \u49900  \u48512 \u45824  5\u44275 \u50640 \u49436  \u44618 \u51060  \u47588 \u52845  \u44032 \u45733 \u54620  \u45936 \u51060 \u53552  \u51076 \u44228 \u51216  \u46020 \u45804 .\
- \uc0\u54532 \u47532 \u48120 \u50628  \u52636 \u49884 , \u49688 \u51061  \u44032 \u49444  \u44160 \u51613 : \u54532 \u47532 \u48120 \u50628  \u44396 \u46021  \u52636 \u49884  (\u50900  4,900\'969,900\u50896  \u46608 \u45716  \u44148 \u45817  9,900\'9614,900\u50896  \'97 A/B \u53580 \u49828 \u53944 ), \u52395  \u50976 \u47308  \u49324 \u50857 \u51088  500\u47749 , MRR \u44160 \u51613 . \u54645 \u49900  \u51648 \u54364 \u45716  \u44160 \u49353  \u8594  \u47588 \u52845  \u54869 \u51064  \u8594  \u50672 \u44208  \u50836 \u52397  \u8594  \u51025 \u45813  \u51204 \u54872 \u50984 , \u47785 \u54364  \u52395  \u45800 \u44228  60% \u51060 \u49345 .\
- \uc0\u49828 \u52992 \u51068 , \u44544 \u47196 \u48268  \u54869 \u51109 : \u45572 \u51201  \u49324 \u50857 \u51088  30,000\u47749 , \u50976 \u47308  2,000\u47749 . 4\u44060 \u44397 \u50612  \u54876 \u49457 \u54868 \u47196  KATUSA\'b7\u54644 \u50808  \u54620 \u51064  \u51204 \u50669 \u51088  \u54400  100\u47749  \u54869 \u48372 . \u48512 \u44032  \u47784 \u46280 (\u51204 \u50864 \u54924 , \u46041 \u44592 \u54924  SaaS) \u49884 \u48276  1\u44148 .\
\
\uc0\u44060 \u51064 \u51221 \u48372 \'b7\u48277 \u51201  \u47532 \u49828 \u53356  \u49444 \u44228  (\u54217 \u44032 \u50948 \u50896  1\u52264  \u50864 \u47140  \u54644 \u49548 )\
- \uc0\u51061 \u47749  \u47588 \u52845  \u8594  \u50672 \u44208  \u50836 \u52397  \u8594  \u49345 \u45824 \u48169  \u46041 \u51032  \u54980  \u50672 \u46973 \u52376  \u44277 \u50976 (\u51060 \u51473  \u50741 \u53944 \u51064 ).\
- \uc0\u44400 \u48264 , \u51204 \u50669 \u51613  \u51064 \u51613 \u51008  PDF \u50629 \u47196 \u46300  + OCR \u51088 \u46041  + \u50868 \u50689 \u51088  \u49324 \u54980  \u44160 \u51613 .\
- \uc0\u44060 \u51064 \u51221 \u48372 \u48372 \u54840 \u48277 , \u51221 \u48372 \u53685 \u49888 \u47581 \u48277  \u51456 \u49688  \u47749 \u49884 , \u48277 \u47924  \u51088 \u47928  1\u44148  \u54869 \u48372  \u50696 \u51221 .\
