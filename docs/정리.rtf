### 2.1 \uc0\u9312  \u52285 \u50629  \u48176 \u44221  (\u50557  850\u51088 )\
\
\uc0\u51200 \u45716  \u50715  \u51204 \u50864 \u47484  \u48512 \u45824 \'b7\u44592 \u49688 \'b7\u51064 \u51613  \u47588 \u52845 \u51004 \u47196  \u45796 \u49884  \u51079 \u45716  1\u51064  \u47588 \u52845  \u54540 \u47019 \u54268  \u50696 \u48708 \u52285 \u50629 \u44032 \u51077 \u45768 \u45796 . React, TypeScript, Vite \u49828 \u53469 \u51004 \u47196  \u51204 \u50864 \u52286 \u44592  \u49436 \u48708 \u49828  MVP 4\u47784 \u46280 \u51012  \u48148 \u51060 \u53356 \u53076 \u46377 \u51004 \u47196  \u50756 \u49457 \u54664 \u44256 , \u52636 \u49884  \u51456 \u48708  \u45800 \u44228 \u50640  \u51080 \u49845 \u45768 \u45796 . \u51200 \u45716  \u50977 \u44400  11\u49324 \u45800  \u49324 \u47161 \u48512 \u50640 \u49436  24\u44060 \u50900 \u51032  \u48373 \u47924 \u44592 \u44036 \u51012  \u44144 \u52824 \u47728  \u44648 \u45804 \u51008  \u54645 \u49900 \u51008 , \u50715  \u44400  \u46041 \u44592 , \u51204 \u50864 \u50752  \u45796 \u49884  \u47564 \u45208 \u44256  \u49910 \u51008  \u50837 \u44396 \u45716  \u48516 \u47749 \u55176  \u51316 \u51116 \u54616 \u45716 \u45936  \u44536  \u50837 \u44396 \u47484  \u50504 \u51204 \u54616 \u44172  \u54400 \u50612 \u51452 \u45716  \u51064 \u54532 \u46972 \u44032  \u54620 \u44397 \u50640  \u50630 \u45796 \u45716  \u49324 \u49892 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\
\uc0\u54644 \u50808 \u50640 \u45716  Together We Served(TWS, \u50557  120\u47564  \u54924 \u50896 ), VetFriends(\u50557  200\u47564  \u54924 \u50896 ) \u44057 \u51008  \u44400  \u52636 \u49888  \u51116 \u54924 \'b7\u51064 \u51613  \u47588 \u52845  \u54540 \u47019 \u54268 \u51060  \u44160 \u51613 \u46108  \u47784 \u45944 \u47196  \u50868 \u50689 \u46121 \u45768 \u45796 . \u54620 \u44397 \u51008  \u44057 \u51008  \u47784 \u45944 \u51060  \u50630 \u49845 \u45768 \u45796 . \u54168 \u51060 \u49828 \u48513  \u48512 \u45824  \u44536 \u47353 \u44284  \u45348 \u51060 \u48260  \u52852 \u54168 \u44032  \u49328 \u48156 \u51201 \u51004 \u47196  \u51088 \u49373 \u54616 \u51648 \u47564 , \u47588 \u52845  \u48320 \u49688 \u44032  \u50630 \u44256  \u51064 \u51613 \u46020  \u50630 \u49845 \u45768 \u45796 .\
\uc0\u51200 \u45716  \u51060  \u44277 \u48177 \u51012  \u54400 \u44592  \u50948 \u54644  \u51089 \u45380 \u48512 \u53552  1\u51064 \u51004 \u47196  \u51204 \u50864 \u52286 \u44592 \u47484  \u51649 \u51217  \u49444 \u44228 , \u44396 \u54788 \u54664 \u49845 \u45768 \u45796 . \u48512 \u45824 , \u44592 \u49688 , \u48372 \u51649 , \u48373 \u47924  \u49884 \u44592  4\u52264 \u50896  \u47588 \u52845  + \u44400 \u48264 \'b7\u51204 \u50669 \u51613  \u51064 \u51613  + \u51060 \u51473  \u50741 \u53944 \u51064  \u50672 \u44208  \u49444 \u44228 \u44032  \u45800 \u51068  \u53076 \u46300 \u48288 \u51060 \u49828 \u50640  \u53685 \u54633  \u50756 \u47308 \u46096 \u44256 , \u48512 \u44032  \u47784 \u46280 (D-Day, \u52404 \u53356 \u47532 \u49828 \u53944 , \u51204 \u47928 \u44032  \u50504 \u45236 )\u51008  \u54924 \u50896  \u50976 \u51077 \u44284  \u52404 \u47448 , \u51109 \u44592  \u51204 \u54872  \u52292 \u45328 \u47196  \u54632 \u44760  \u44396 \u54788 \u54664 \u49845 \u45768 \u45796 . \
\uc0\u47784 \u46160 \u51032  \u52285 \u50629  \u44592 \u49696  \u53944 \u47001 \u51008  0\u8594 1 \u53076 \u46300 \u47484  \u50756 \u49457 \u54620  \u49324 \u46988 \u51060  \u52636 \u49884 \'b7\u44160 \u51613 \'b7\u49828 \u52992 \u51068 \u50629 \u51012  \u44032 \u49549 \u54624  \u49688  \u51080 \u45716  \u47924 \u45824 \u46972 \u44256  \u48389 \u45768 \u45796 . \u50715  \u51204 \u50864 \u47484  \u48512 \u45824 , \u44592 \u49688 , \u48372 \u51649  \u47588 \u52845 \u44284  \u44400 \u48264  \u51064 \u51613 \u51004 \u47196  \u50504 \u51204 \u54616 \u44172  \u51116 \u54924 \u49884 \u53412 \u45716  \u47588 \u52845  \u54540 \u47019 \u54268 \u51012 , 4\u44060 \u44397 \u50612  \u50868 \u50689 \u51012  \u44592 \u48152 \u51004 \u47196  \u54620 \u44397 \u50640 \u49436  \u44544 \u47196 \u48268  \u54620 \u51064  \u51204 \u50669 \u51088 \u44620 \u51648  \u54869 \u51109 \u54616 \u44192 \u49845 \u45768 \u45796 .\
\'97\
\
\uc0\u50612 \u45712  \u45216  \u50976 \u53804 \u48652 \u47484  \u48372 \u45796 \u44032  \u50612 \u45712  \u50696 \u51204 \u51032  \u44397 \u44400 \u48169 \u49569 \u51032  \u54868 \u47732 \u51012  \u48380  \u49688  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44536 \u46412  \u51200 \u46020  \u54620 \u48264  \u49373 \u44033 \u54644 \u48420 \u49845 \u45768 \u45796 . \u51200 \u50640 \u44172 \u46020  \u51200 \u46412 \u44032  \u51080 \u50632 \u44256  \u54632 \u44760  \u54984 \u47144 \u54616 \u47732 \u49436  \u46041 \u44256 \u46041 \u46973 \u54664 \u45912  \u51204 \u50864 \u46308 \u51032  \u47784 \u49845 \u46308 \u51060  \u46496 \u50732 \u46992 \u49845 \u45768 \u45796 . \u44536 \u47000 \u49436  \u51200 \u46020  \u47928 \u46301   \u54168 \u51060 \u49828 \u48513 \u50640  \u51060 \u47492 \u51012  \u44160 \u49353 \u54644 \u48420 \u49845 \u45768 \u45796 . \u46041 \u47749 \u51060 \u51064 \u51060  \u49688 \u49901  \u47749  \u45208 \u50772 \u49845 \u45768 \u45796 . \u50612 \u45712  \u44172  \u44536  \u49324 \u46988 \u51064 \u51648  \u50508  \u44600 \u51060  \u50630 \u50632 \u49845 \u45768 \u45796 . \u44060 \u47749 \u54664 \u45716 \u51648 , \u54644 \u50808 \u50640  \u44052 \u45716 \u51648 , SNS\u47484  \u50504  \u50416 \u45716 \u51648 \u46020  \u50508  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 . \u44400 \u50640  \u47749 \u45800 \u51012  \u50836 \u52397 \u54624  \u49688 \u46020  \u50630 \u50632 \u49845 \u45768 \u45796  \'97 \u44060 \u51064 \u51221 \u48372 \u48372 \u54840 \u48277  \u46412 \u47928 \u50640  \u48512 \u45824  \u45800 \u50948  \u47749 \u45800 \u51008  \u44277 \u44060 \u46104 \u51648  \u50506 \u49845 \u45768 \u45796 .\
\uc0\u48169 \u48277 \u51012  \u52286 \u45796 \u44032  \u54644 \u50808  \u49324 \u47168 \u47484  \u50508 \u44172  \u46096 \u49845 \u45768 \u45796 . \u48120 \u44397  Together We Served\u45716  \u50557  120\u47564  \u47749 , VetFriends\u45716  \u50557  200\u47564  \u47749 \u51060  \u48512 \u45824 \'b7\u44592 \u49688  \u44592 \u48152  \u47588 \u52845 \u44284  \u44400  \u48373 \u47924  \u51064 \u51613 \u51004 \u47196  \u50715  \u51204 \u50864 \u47484  \u45796 \u49884  \u47564 \u45208 \u45716  \u47784 \u45944 \u51012  \u50868 \u50689  \u51473 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44057 \u51008  \u47784 \u45944 \u51060  \u54620 \u44397 \u50640 \u45716  \u50630 \u50632 \u49845 \u45768 \u45796 . \u54168 \u51060 \u49828 \u48513  \u48512 \u45824  \u44536 \u47353 \u51060 \u45208  \u45348 \u51060 \u48260  \u52852 \u54168 \u44032  \u49328 \u48156 \u51201 \u51004 \u47196  \u51080 \u50632 \u51648 \u47564 , \u47588 \u52845  \u48320 \u49688 \u44032  \u50630 \u44256  \u51064 \u51613 \u46020  \u50630 \u50612  "\u51080 \u51012  \u53584 \u45936  \u47803  \u52286 \u45716 " \u49345 \u53468 \u45716  \u44536 \u45824 \u47196 \u50688 \u49845 \u45768 \u45796 .\
\uc0\u51200 \u45716  \u51060  \u44277 \u48177 \u51012  \u51649 \u51217  \u54400 \u50612 \u48372 \u44592 \u47196  \u54664 \u49845 \u45768 \u45796 . React, TypeScript, Vite\u47484  \u44592 \u48152 \u51004 \u47196 \u54616 \u45716  \u48148 \u51060 \u53356  \u53076 \u46377 \u51004 \u47196  \u50937 \u54168 \u51060 \u51648 \u47484  \u44396 \u52629 \u54616 \u50688 \u49845 \u45768 \u45796 . \u48512 \u45824 , \u44592 \u49688 , \u48372 \u51649 , \u48373 \u47924  \u49884 \u44592  4\u52264 \u50896  \u47588 \u52845 , \u44400 \u48264 , \u51204 \u50669 \u51613  \u51064 \u51613 , \u51061 \u47749  \u47588 \u52845 \u50640 \u49436  \u50672 \u44208  \u50836 \u52397 , \u46041 \u51032  \u54980  \u50672 \u46973 \u52376  \u44277 \u50976 \u47196  \u51060 \u50612 \u51648 \u45716  \u51060 \u51473  \u50741 \u53944 \u51064  \u55120 \u47492 \u51012  \u45800 \u51068  \u53076 \u46300 \u48288 \u51060 \u49828 \u50640  \u53685 \u54633 \u54664 \u49845 \u45768 \u45796 . \u48512 \u44032  \u47784 \u46280 \u47196  D-Day \u44228 \u49328 \u44592 , \u51204 \u50669  \u51456 \u48708  \u52404 \u53356 \u47532 \u49828 \u53944 , \u50808 \u48512  \u51204 \u47928 \u44032  \u50504 \u45236 \u47484  \u54632 \u44760  \u44396 \u54788 \u54644  \u54788 \u50669 \'b7\u51204 \u50669  \u51649 \u54980  \u52397 \u45380 \u51060  \u46308 \u50612 \u50732  \u50976 \u51077  \u52292 \u45328 \u46020  \u47564 \u46308 \u50632 \u49845 \u45768 \u45796 . \u49324 \u50857 \u51088 \u45716  \u50500 \u51649  0\u51060 \u51648 \u47564 , \u49324 \u50857 \u51088 \u47484  \u48155 \u51012  \u44536 \u47495 \u51008  \u50756 \u49457 \u54664 \u49845 \u45768 \u45796 . \u51200 \u45716  \u51060 \u51228  \u52636 \u49884 \'b7\u44160 \u51613 \'b7\u49828 \u52992 \u51068 \u50629  \u45800 \u44228 \u47196  \u45336 \u50612 \u44032 \u47140  \u54633 \u45768 \u45796 . \u44536  \u44032 \u49549 \u51012  \u47784 \u46160 \u51032  \u52285 \u50629 \u50640 \u49436  \u48155 \u44256 \u51088  \u54633 \u45768 \u45796 .\
