### 2.2 \uc0\u9313  \u44256 \u44061  \u47928 \u51228 \'b7\u45768 \u51592  (\u50557  900\u51088 ) \'97 \u54217 \u44032  \u48708 \u51473  \u52572 \u45824 \
\
\uc0\u51204 \u50669  \u54980  5~30\u45380 \u51060  \u51648 \u45212  \u51204 \u50669 \u51088  \u51473  \u50715  \u44400  \u46041 \u44592 , \u51204 \u50864 \u50752  \u45796 \u49884  \u47564 \u45208 \u44256  \u49910 \u51008  \u50837 \u44396 \u44032  \u48516 \u47749 \u54620  \u49324 \u46988 \u51077 \u45768 \u45796 . \u54620 \u44397  \u45572 \u51201  \u51204 \u50669 \u51088  \u54400 \u51008  \u53685 \u44228 \u52397  \u51064 \u44396  \u53685 \u44228 \u49345  30\'9660\u45824  \u45224 \u49457 \u47564  \u46384 \u51256 \u46020  1,000\u47564  \u51060 \u49345 \u51060 \u44256 , \u47588 \u45380  \u49888 \u44508  25\u47564  \u47749 \u51060  \u52628 \u44032 \u46121 \u45768 \u45796 . \
\
\uc0\u52395 \u51704 , \u50672 \u46973  \u45800 \u51208  \u44400  \u49884 \u51208  \u52828 \u44396 \u51032  \u50672 \u46973 \u52376 \u45716  5\'9610\u45380 \u51060  \u51648 \u45208 \u47732  \u45824 \u48512 \u48516  \u49324 \u46972 \u51665 \u45768 \u45796 . \u48512 \u45824 \'b7\u44592 \u49688  \u45800 \u50948  \u47749 \u45800 \u51008  \u44060 \u51064 \u51221 \u48372 \u48372 \u54840 \u48277 \u50640  \u46384 \u46972  \u44400  \u52769 \u50640 \u49436  \u48708 \u44277 \u44060 \u47196  \u50976 \u51648 \u46121 \u45768 \u45796 . \u51088 \u49373 \u51201  \u46041 \u44592 \u54924 \'b7\u51204 \u50864 \u54924 \u45716  \u51068 \u48512  \u51064 \u44592  \u48512 \u45824 \u50640  \u54620 \u51221 \u46104 \u44256 , \u45824 \u48512 \u48516 \u51032  \u48512 \u45824 \u45716  \u44536 \u51312 \u52264  \u50630 \u49845 \u45768 \u45796 .\
\
**\uc0\u46168 \u51704 , \u51060 \u47492 \'b7\u44592 \u50613 \u47564 \u51004 \u47196  \u47803  \u52286 \u51020  \'97 \u44032 \u51109  \u53360  \u54168 \u51064 .** \u54168 \u51060 \u49828 \u48513 \'b7\u45348 \u51060 \u48260 \u50640 \u49436  \u50715  \u46041 \u44592  \u51060 \u47492 \u51004 \u47196  \u44160 \u49353 \u54644 \u46020  \u46041 \u47749 \u51060 \u51064 \'b7\u44060 \u47749 \'b7\u54644 \u50808  \u51060 \u51452 \'b7SNS \u48120 \u49324 \u50857  \u46321 \u51004 \u47196  \u46020 \u45804 \u51060  \u50612 \u47157 \u49845 \u45768 \u45796 . \u44208 \u44284 \u51201 \u51004 \u47196  \u50715  \u51204 \u50864 \u45716  *"\u51080 \u51012  \u53584 \u45936  \u47803  \u52286 \u45716 "* \u49345 \u53468 \u44032  \u54217 \u49373  \u51060 \u50612 \u51665 \u45768 \u45796 . `[\u46272 \u53356  \u51064 \u49436 \u53944 : \u48376 \u51064  \u46608 \u45716  \u51648 \u51064 \u51032  \u49892 \u51228  \u49324 \u47168  \u54620  \u47928 \u51109 ]`\
\
**\uc0\u49483 \u51704 , \u51064 \u51613 \'b7\u49888 \u47280  \u48512 \u51116 .** "\u51060  \u49324 \u46988 \u51060  \u51652 \u51676  \u50864 \u47532  \u48512 \u45824  \u46041 \u44592 \u51064 \u44032 "\u47484  \u54869 \u51064 \u54624  \u48169 \u48277 \u51060  \u50630 \u49845 \u45768 \u45796 . \u54168 \u51060 \u49828 \u48513  \u48512 \u45824  \u44536 \u47353 \u51008  \u44032 \u51077 \u51088  \u44160 \u51613 \u51060  \u50557 \u54644  \u49324 \u52845 \'b7\u50501 \u50857 \'b7\u49828 \u53664 \u53433  \u50948 \u54744 \u51060  \u49345 \u51316 \u54616 \u44256 , \u51060  \u50864 \u47140  \u51088 \u52404 \u44032  \u51088 \u49373 \u51201  \u44536 \u47353  \u50868 \u50689 \u51032  \u54620 \u44228 \u47196  \u51089 \u46041 \u54633 \u45768 \u45796 . \u50715  \u51204 \u50864  \u52286 \u44592 \u45716  *"\u50504 \u51204 \u54620  \u51064 \u51613 \u46108  \u47588 \u52845 "* \u50630 \u51060 \u45716  \u54400 \u47532 \u51648  \u50506 \u45716  \u47928 \u51228 \u51077 \u45768 \u45796 .\
\
\uc0\u54644 \u50808 \u50640 \u45716  \u51060  \u51221 \u54869 \u54620  \u54168 \u51064 \u51012  \u54392 \u45716  \u44160 \u51613 \u46108  \u47784 \u45944 \u51060  \u51080 \u49845 \u45768 \u45796  \'97 **TWS \u50557  120\u47564  \u54924 \u50896 , VetFriends \u50557  200\u47564  \u54924 \u50896 **. \u46168  \u45796  \u48512 \u45824 \'b7\u44592 \u49688  \u44592 \u48152  \u47588 \u52845  + \u44400  \u48373 \u47924  \u51064 \u51613  + \u50976 \u47308  \u47716 \u48260 \u49901  \u47784 \u45944 \u47196  \u49688 \u51061 \u54868 \u50640  \u49457 \u44277 \u54664 \u44256 , \u54620 \u44397 \u54805 \u51008  \u48512 \u51116 \u54633 \u45768 \u45796 .\
\
\uc0\u52397 \u45380 \u51032  \u52628 \u44032  \u45768 \u51592 \u46020  \u48512 \u44032  \u47784 \u46280 \u47196  \u51105 \u54784  \u51080 \u49845 \u45768 \u45796  \'97 \u51204 \u50669  D-Day \u44228 \u49328 \u44592 , \u51204 \u50669  \u51456 \u48708  \u52404 \u53356 \u47532 \u49828 \u53944 , \u50808 \u48512  \u51204 \u47928 \u44032  \u50504 \u45236 . \u51060 \u45716  \u54788 \u50669 \'b7\u51204 \u50669  \u51649 \u54980  \u52397 \u45380 \u51060  \u51088 \u50672 \u49828 \u47101 \u44172  \u51652 \u51077 \u54644  \u51109 \u44592  \u49324 \u50857 \u51088 \u47196  \u51204 \u54872 \u46104 \u45716  \u50976 \u51077  \u52292 \u45328 \u51077 \u45768 \u45796 .\
\
\uc0\u54645 \u49900  \u44256 \u44061 \u51032  \u54620  \u51460  \u45768 \u51592 \u45716  *"\u50715  \u51204 \u50864 \u47484  \u50504 \u51204 \u54616 \u44172 , \u51064 \u51613 \u46108  \u48169 \u49885 \u51004 \u47196 , \u45796 \u49884  \u47564 \u45208 \u44256  \u49910 \u45796 "*\u51060 \u47728 , \u51060 \u47484  \u54620  \u44275 \u50640 \u49436  \u54644 \u44208 \u54616 \u45716  \u49556 \u47336 \u49496 \u51008  \u54620 \u44397  \u49884 \u51109 \u50640  \u50630 \u49845 \u45768 \u45796 . **\u51204 \u50864 \u52286 \u44592 **\u44032  \u52292 \u50872  \u51221 \u54869 \u54620  \u44277 \u48177 \u51077 \u45768 \u45796 .\
