\uc0\u54645 \u49900  \u44256 \u44061 \u51008  \u51204 \u50669  \u54980  5~30\u45380 \u51060  \u51648 \u45212  \u51204 \u50669 \u51088 \u51077 \u45768 \u45796 . 30\u45824  \u54980 \u48152 \u50640 \u49436  60\u45824  \u51060 \u49345 \u44620 \u51648 , \u50715  \u44400  \u46041 \u44592 , \u51204 \u50864 \u50752  \u45796 \u49884  \u47564 \u45208 \u44256  \u49910 \u51008  \u50837 \u44396 \u44032  \u48516 \u47749 \u54620  \u49324 \u46988 \u46308 \u51077 \u45768 \u45796 . \u54620 \u44397  \u45572 \u51201  \u51204 \u50669 \u51088  \u54400 \u51008  30~60\u45824  \u45224 \u49457  \u51064 \u44396  \u44592 \u51456  1,000\u47564  \u47749 \u51012  \u45336 \u49845 \u45768 \u45796 . \u48512 \u44032  \u44256 \u44061 \u51008  \u54788 \u50669 , \u51204 \u50669  \u51649 \u54980  \u52397 \u45380 \u51004 \u47196 , D-Day \u44228 \u49328 \u44592 \u50752  \u51204 \u50669  \u51456 \u48708  \u52404 \u53356 \u47532 \u49828 \u53944  \u44057 \u51008  \u48512 \u44032  \u47784 \u46280 \u47196  \u50976 \u51077 \u46076  \u51109 \u44592 \u51201 \u51004 \u47196  \u54645 \u49900  \u49324 \u50857 \u51088  \u54400 \u50640  \u54633 \u47448 \u54633 \u45768 \u45796 .\
\uc0\u51060 \u46308 \u51060  \u47560 \u51452 \u54620  \u47928 \u51228 \u45716  \u49464  \u44032 \u51648 \u51077 \u45768 \u45796 .\
\
\uc0\u52395 \u51704 , \u50672 \u46973  \u45800 \u51208 . \u44400  \u49884 \u51208  \u52828 \u44396 \u51032  \u50672 \u46973 \u52376 \u45716  \u51204 \u50669  \u54980  5~10\u45380 \u51060  \u51648 \u45208 \u47732  \u45824 \u48512 \u48516  \u49324 \u46972 \u51665 \u45768 \u45796 . \u48512 \u45824 , \u44592 \u49688  \u45800 \u50948  \u47749 \u45800 \u51008  \u44060 \u51064 \u51221 \u48372 \u48372 \u54840 \u48277  \u46412 \u47928 \u50640  \u44400  \u52769 \u50640 \u49436  \u44277 \u44060 \u54616 \u51648  \u50506 \u49845 \u45768 \u45796 . \u51088 \u49373 \u51201  \u46041 \u44592 \u54924 , \u51204 \u50864 \u54924 \u45716  \u51068 \u48512  \u51064 \u44592  \u48512 \u45824 \u50640  \u54620 \u51221 \u46104 \u44256 , \u45824 \u48512 \u48516 \u51032  \u48512 \u45824 \u45716  \u44536 \u51312 \u52264  \u50630 \u49845 \u45768 \u45796 .\
\
\uc0\u46168 \u51704 , \u44032 \u51109  \u53360  \u54168 \u51064 \u51064  \u51060 \u47492 \u47564 \u51004 \u47196 \u45716  \u47803 \u52286 \u51020 . \u54168 \u51060 \u49828 \u48513 , \u45348 \u51060 \u48260 \u50640 \u49436  \u50715  \u46041 \u44592  \u51060 \u47492 \u51004 \u47196  \u44160 \u49353 \u54616 \u47732  \u46041 \u47749 \u51060 \u51064 \u51060  \u49688 \u49901  \u47749  \u45208 \u50741 \u45768 \u45796 . \u44060 \u47749 , \u54644 \u50808  \u51060 \u51452 , SNS \u48120 \u49324 \u50857 \u44620 \u51648  \u54633 \u52824 \u47732  \u46020 \u45804  \u48520 \u44032 \u44032  \u51068 \u49345 \u51077 \u45768 \u45796 . \u44208 \u44284 \u45716  "\u51080 \u51012  \u53584 \u45936  \u47803  \u52286 \u45716 " \u49345 \u53468 \u44032  \u54217 \u49373  \u51060 \u50612 \u51648 \u45716  \u44163 \u51077 \u45768 \u45796 .\
\
\uc0\u49483 \u51704 , \u51064 \u51613 \u44284  \u49888 \u47280  \u48512 \u51116 . "\u51060  \u49324 \u46988 \u51060  \u51652 \u51676  \u50864 \u47532  \u48512 \u45824  \u46041 \u44592 \u51064 \u44032 "\u47484  \u54869 \u51064 \u54624  \u48169 \u48277 \u51060  \u50630 \u49845 \u45768 \u45796 . \u54168 \u51060 \u49828 \u48513  \u48512 \u45824  \u44536 \u47353 \u51008  \u44032 \u51077 \u51088  \u44160 \u51613 \u51060  \u50557 \u54644  \u49324 \u52845 , \u50501 \u50857 , \u49828 \u53664 \u53433  \u50948 \u54744 \u51060  \u49345 \u51316 \u54616 \u44256 , \u51060  \u50864 \u47140  \u51088 \u52404 \u44032  \u51088 \u49373 \u51201  \u44536 \u47353  \u50868 \u50689 \u51032  \u54620 \u44228 \u51077 \u45768 \u45796 .\
\uc0\u51204 \u50864 \u52286 \u44592 \u45716  \u51060  \u49464  \u54168 \u51064 \u51012  \u54620 \u44732 \u48264 \u50640  \u54409 \u45768 \u45796 . \u48512 \u45824 , \u44592 \u49688 , \u48372 \u51649 , \u48373 \u47924  \u49884 \u44592  4\u52264 \u50896  \u47588 \u52845 \u51004 \u47196  \u51060 \u47492 \u51060  \u50500 \u45768 \u46972  \u44400  \u49884 \u51208 \u51032  \u48320 \u49688 \u47196  \u49324 \u46988 \u51012  \u52286 \u49845 \u45768 \u45796 . \u44400 \u48264 , \u51204 \u50669 \u51613  \u51064 \u51613 (OCR \u51088 \u46041  \u44160 \u51613  + \u50868 \u50689 \u51088  \u49324 \u54980  \u48372 \u51221 )\u51004 \u47196  \u49324 \u52845 \u51012  \u52264 \u45800 \u54633 \u45768 \u45796 . \u51060 \u51473  \u50741 \u53944 \u51064  \u50672 \u44208 (\u51061 \u47749  \u47588 \u52845  \u8594  \u50672 \u44208  \u50836 \u52397  \u8594  \u49345 \u45824 \u48169  \u46041 \u51032  \u54980  \u50672 \u46973 \u52376  \u44277 \u50976 )\u47196  \u49828 \u53664 \u53433 , \u50501 \u50857 \u51012  \u47561 \u49845 \u45768 \u45796 . \
